---
layout: null
permalink: /search.json
---
[
{% assign first = true %}
{% assign documents = site.pages | concat: site.posts %}
{% for item in documents %}
  {% unless item.url contains '/search.json' or item.url contains '/assets/' or item.url contains '/404' or item.title == nil %}
    {% unless first %},{% endunless %}
    {
      "title": {{ item.title | default: item.name | jsonify }},
      "url": {{ item.url | relative_url | jsonify }},
      "content": {{ item.content | strip_html | normalize_whitespace | jsonify }}
    }
    {% assign first = false %}
  {% endunless %}
{% endfor %}
]
